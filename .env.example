# Supabase プロジェクトの設定値をコピーして .env.local を作成してください
# Supabase Dashboard > Project Settings > API Keys から取得できます

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (sb_publishable_...): クライアントに公開してよいキー
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (sb_secret_...): サーバーサイド専用・RLS をバイパスする（絶対にクライアントへ公開しないこと）
SUPABASE_SECRET_KEY=sb_secret_...
